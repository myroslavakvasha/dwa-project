@model WebApp.ViewModels.Food.FoodIndexVM;

@{
	ViewData["Title"] = "Food list";
}

@section Styles {
	<link rel="stylesheet" href="/css/index.css" />
}

<div class="food-index-container">
    <form asp-action="Index" method="GET">
        <div class="food-toolbar">
            <input asp-for="Q" class="food-search-input" placeholder="Search food" />
            <select asp-for="CategoryId" asp-items="Model.Categories" class="food-category-select">
                <option value="">-- All categories --</option>
            </select>
            <button type="submit" class="btn-search">Search</button>
        </div>
        <div class="food-size-bar">
            Show
            <a asp-action="Index" asp-route-q="@Model.Q" asp-route-categoryId="@Model.CategoryId" asp-route-page="1" asp-route-size="5" class="@(Model.Size == 5 ? "size-link active" : "size-link")">5</a> |
            <a asp-action="Index" asp-route-q="@Model.Q" asp-route-categoryId="@Model.CategoryId" asp-route-page="1" asp-route-size="10" class="@(Model.Size == 10 ? "size-link active" : "size-link")">10</a> |
            <a asp-action="Index" asp-route-q="@Model.Q" asp-route-categoryId="@Model.CategoryId" asp-route-page="1" asp-route-size="30" class="@(Model.Size == 30 ? "size-link active" : "size-link")">30</a>
            Items
        </div>
    </form>

    <div class="food-list-header">
        @* can be done by reading annotations but doesnt make sense here ig *@
        @* <span>@Html.DisplayNameFor(x => x.Foods.First().CategoryName)</span> *@
        <span>Name</span>
        <span>Description</span>
        <span>Category — Price — Weight</span>
        <span>Management</span>
    </div>

    <div class="food-list">
        @foreach (var item in Model.Foods)
        {
            <div class="food-row">
                <span class="food-row-name">@item.Name</span>
                <span class="food-row-desc">@item.Description</span>
                <span class="food-row-meta">@item.CategoryName — €@item.Price.ToString("0.00") — @item.Weight g</span>
    
                <div class="food-row-actions">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn-edit">Edit</a>
                    <a asp-controller="FoodAllergen" asp-action="Manage" asp-route-foodId="@item.Id" class="btn-allergen">Allergens</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn-delete">Delete</a>
                </div>
            </div>
        }
    </div>

    <div class="food-bottom-bar">
        <ul class="food-pagination">
            @for (int i = Model.FromPager; i <= Model.ToPager; i++)
            {
                var linkText = i.ToString();
                if (i != 1 && i == Model.FromPager) linkText = "«";
                else if (i != Model.LastPage && i == Model.ToPager) linkText = "»";

                <li class="page-item @(i == Model.Page ? "active" : "")">
                    @Html.ActionLink(linkText, "Index", new { q = Model.Q, categoryId = Model.CategoryId, page = i, size = Model.Size }, new { @class = "page-link" })
                </li>
            }
        </ul>
        <a asp-action="Create" class="btn-create">Add Item</a>
    </div>
</div>