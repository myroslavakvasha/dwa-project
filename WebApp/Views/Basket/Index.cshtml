@model WebApp.ViewModels.Menu.BasketIndexVM

@{
    ViewData["Title"] = "Your Basket";
}

<link rel="stylesheet" href="~/css/index.css" />

<div class="food-index-container">
    <div class="food-page-header">
        <p class="food-index-label">Mandry Restaurant</p>
        <h1 class="food-index-title">Your Basket</h1>
    </div>

    @if (!Model.Items.Any())
    {
        <p style="text-align:center; color:#999; margin-top:40px;">Your basket is empty.</p>
        <div class="basket-actions" style="margin-top:24px;">
            @Html.ActionLink("← Back to Menu", "Index", "Menu", null, new { @class = "btn-edit" })
        </div>
    }
    else
    {
        <div class="food-list" style="margin-top: 32px;">
            <div class="food-list-header">
                <span style="flex: 0 0 60px;"></span>
                <span style="flex: 1;">Item</span>
                <span style="min-width: 100px; text-align:right;">Price</span>
                <span style="min-width: 80px; text-align:center;">Qty</span>
                <span style="min-width: 100px; text-align:right;">Subtotal</span>
                <span style="width: 100px; margin-left:16px;"></span>
            </div>

            @foreach (var item in Model.Items)
            {
                <div class="food-row">
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" class="food-row-img" />
                    }
                    else
                    {
                        <div class="food-row-img"></div>
                    }

                    <span class="food-row-name" style="flex:1;">@item.Name</span>

                    <span class="food-row-meta" style="min-width:100px; text-align:right;">
                        $@item.Price.ToString("0.00")
                    </span>

                    <span class="food-row-center">@item.Quantity</span>

                    <span class="food-row-total">
                        $@((item.Price * item.Quantity).ToString("0.00"))
                    </span>

                    <div style="width:100px; margin-left:16px; display:flex; justify-content:flex-end;">
                        <form method="post" asp-controller="Basket" asp-action="Remove">
                            <input type="hidden" name="foodId" value="@item.FoodId" />
                            <button type="submit" class="btn-delete">Remove</button>
                        </form>
                    </div>
                </div>
            }
        </div>

        <div class="basket-total">
            Total: $@Model.TotalPrice.ToString("0.00")
        </div>

        <form method="post" asp-controller="Basket" asp-action="PlaceOrder" style="margin-top:32px;">
            @Html.AntiForgeryToken()

            <div style="margin-bottom:16px;">
                <label class="basket-form-label">Payment Method</label>
                @Html.DropDownListFor(x => x.PaymentType, Model.Payments, "-- Select --", new { @class = "food-category-select" })
                @Html.ValidationMessageFor(x => x.PaymentType, "", new { @style = "color:#c0392b; font-size:12px;" })
            </div>

            <div style="margin-bottom:24px;">
                <label class="basket-form-label">Comment (optional)</label>
                @Html.TextAreaFor(x => x.Comment, new { @class = "food-search-input", rows = "3", style = "width:100%; resize:vertical;" })
            </div>

            <div class="basket-actions">
                @Html.ActionLink("← Back to Menu", "Index", "Menu", null, new { @class = "btn-edit" })
                <button type="submit" class="btn-create">Place Order</button>
            </div>
        </form>
    }
</div>