@model WebApp.ViewModels.Menu.BasketIndexVM

@{
    ViewData["Title"] = "Your Basket";
}

<link rel="stylesheet" href="~/css/index.css" />
<link rel="stylesheet" href="~/css/basket.css" />

<div class="food-index-container">
    <div class="food-page-header">
        <p class="food-index-label">Mandry Restaurant</p>
        <h1 class="food-index-title">Your Basket</h1>
    </div>

    @if (!Model.Items.Any())
    {
        <p class="basket-empty">Your basket is empty.</p>
        <div class="basket-actions basket-empty-actions">
            @Html.ActionLink("← Back to Menu", "Index", "Menu", null, new { @class = "btn-edit" })
        </div>
    }
    else
    {
        <div class="food-list basket-list">
            <div class="basket-list-header">
                <span class="basket-col-img"></span>
                <span class="basket-col-name">Item</span>
                <span class="basket-col-price">Price</span>
                <span class="basket-col-qty">Qty</span>
                <span class="basket-col-subtotal">Subtotal</span>
                <span class="basket-col-remove"></span>
            </div>

            @foreach (var item in Model.Items)
            {
                <div class="food-row">
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" class="food-row-img" />
                    }
                    else
                    {
                        <div class="food-row-img"></div>
                    }

                    <span class="food-row-name">@item.Name</span>
                    <span class="basket-col-price">$@item.Price.ToString("0.00")</span>
                    <span class="food-row-center">@item.Quantity</span>
                    <span class="food-row-total">$@((item.Price * item.Quantity).ToString("0.00"))</span>

                    <div class="basket-col-remove basket-row-remove">
                        <form method="post" asp-controller="Basket" asp-action="Remove">
                            <input type="hidden" name="foodId" value="@item.FoodId" />
                            <button type="submit" class="btn-delete">Remove</button>
                        </form>
                    </div>
                </div>
            }
        </div>

        <div class="basket-total">
            Total: $@Model.TotalPrice.ToString("0.00")
        </div>

        <form method="post" asp-controller="Basket" asp-action="PlaceOrder" class="basket-order-form">
            <div class="basket-form-group">
                <label class="basket-form-label">Payment Method</label>
                @Html.DropDownListFor(x => x.PaymentType, Model.Payments, "-- Select --", new { @class = "food-category-select" })
                @Html.ValidationMessageFor(x => x.PaymentType)
            </div>

            <div class="basket-comment-group">
                <label class="basket-form-label">Comment (optional)</label>
                @Html.TextAreaFor(x => x.Comment, new { @class = "food-search-input basket-comment", rows = "3" })
            </div>

            <div class="basket-actions">
                @Html.ActionLink("← Back to Menu", "Index", "Menu", null, new { @class = "btn-edit" })
                <button type="submit" class="btn-create">Place Order</button>
            </div>
        </form>
    }
</div>
