@model WebApp.ViewModels.Auth.ChangePasswordVM

@{
    ViewData["Title"] = "Change Password";
}

<link rel="stylesheet" href="~/css/form.css" />

<div class="food-form-wrapper">
    <div class="food-form-container">
        <h1>Account</h1>
        <h2>Change Password</h2>

        <form id="changePasswordForm">
            <div class="food-form-grid">
                <div class="food-form-group field-full">
                    <label asp-for="OldPassword"></label>
                    <input asp-for="OldPassword" type="password" />
                    <span asp-validation-for="OldPassword" class="field-validation-error"></span>
                </div>

                <div class="food-form-group field-full">
                    <label asp-for="NewPassword"></label>
                    <input asp-for="NewPassword" type="password" />
                    <span asp-validation-for="NewPassword" class="field-validation-error"></span>
                </div>

                <div class="food-form-group field-full">
                    <label asp-for="ConfirmPassword"></label>
                    <input asp-for="ConfirmPassword" type="password" />
                    <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
                </div>
            </div>

            <div id="passwordMessage"></div>

            <div class="food-form-actions">
                <a asp-action="Profile" class="btn-cancel">Cancel</a>
                <button type="submit" class="btn-save">Save</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        $("#changePasswordForm").submit(function (e) {
            e.preventDefault();

            $.ajax({
                url: '@Url.Action("SavePassword", "Auth")',
                method: "POST",
                data: $(this).serialize(),
                success: function (response) {
                    if (response.success) {
                        $("#passwordMessage").html('<p style="color: green; font-size: 13px;">Password changed successfully.</p>');
                    } else {
                        $("#passwordMessage").html('<p style="color: #c0392b; font-size: 13px;">' + response.message + '</p>');
                    }
                },
                error: function () {
                    $("#passwordMessage").html('<p style="color: #c0392b; font-size: 13px;">Something went wrong.</p>');
                }
            });
        });
    </script>
}