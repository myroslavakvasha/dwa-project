@model WebApp.ViewModels.Auth.ProfileVM

@{
    ViewData["Title"] = "Profile";
}

<link rel="stylesheet" href="~/css/form.css" />

<div class="food-form-wrapper">
    <div class="food-form-container">
        <h1>Account</h1>
        <h2>My Profile</h2>

        <form id="profileForm">
            <div class="food-form-grid">
                <div class="food-form-group">
                    <label>Username</label>
                    <input type="text" value="@Model.Username" disabled />
                </div>

                <div class="food-form-group">
                    <label asp-for="Email"></label>
                    <input asp-for="Email" type="text" />
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>

                <div class="food-form-group">
                    <label asp-for="FirstName"></label>
                    <input asp-for="FirstName" type="text" />
                    <span asp-validation-for="FirstName" class="field-validation-error"></span>
                </div>

                <div class="food-form-group">
                    <label asp-for="LastName"></label>
                    <input asp-for="LastName" type="text" />
                    <span asp-validation-for="LastName" class="field-validation-error"></span>
                </div>

                <div class="food-form-group">
                    <label asp-for="Phone"></label>
                    <input asp-for="Phone" type="text" />
                    <span asp-validation-for="Phone" class="field-validation-error"></span>
                </div>
            </div>

            <div id="profileMessage"></div>

            <div class="food-form-actions">
                <a asp-action="ChangePassword" class="btn-cancel">Change Password</a>
                <button type="submit" class="btn-save">Save</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        $("#profileForm").submit(function (e) {
            e.preventDefault();

            $.ajax({
                url: '@Url.Action("SaveProfile", "Auth")',
                method: "POST",
                data: $(this).serialize(),
                success: function (response) {
                    if (response.success) {
                        $("#profileMessage").html('<p style="color: green; font-size: 13px;">Profile updated successfully.</p>');
                    } else {
                        $("#profileMessage").html('<p style="color: #c0392b; font-size: 13px;">' + response.message + '</p>');
                    }
                },
                error: function () {
                    $("#profileMessage").html('<p style="color: #c0392b; font-size: 13px;">Something went wrong.</p>');
                }
            });
        });
    </script>
}