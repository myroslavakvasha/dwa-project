@model WebApp.ViewModels.Menu.MenuDetailsVM

@{
    ViewData["Title"] = Model.Name;
}

@section Styles {
    <link rel="stylesheet" href="/css/menu-details.css" />
}

<div class="detail-wrapper">
    <div class="detail-card">

        <p class="detail-category-label">@Model.CategoryName</p>
        <h1 class="detail-title">@Model.Name</h1>

        <div class="detail-body">
            <div class="detail-image-col">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" alt="@Model.Name" class="detail-image" />
                }
                else
                {
                    <div class="detail-image-placeholder">No image</div>
                }
            </div>

            <div class="detail-info-col">
                <div class="detail-price">€@Model.Price.ToString("0.00")</div>

                <div class="detail-attr">
                    <span class="detail-attr-label">Weight</span>
                    <span class="detail-attr-value">@Model.Weight g</span>
                </div>
                <div class="detail-attr">
                    <span class="detail-attr-label">Category</span>
                    <span class="detail-attr-value">@Model.CategoryName</span>
                </div>

                @if (Model.Allergens != null && Model.Allergens.Any())
                {
                    <div class="detail-attr detail-attr--allergens">
                        <span class="detail-attr-label">Allergens</span>
                        <div class="detail-allergen-list">
                            @foreach (var allergen in Model.Allergens)
                            {
                                <span class="detail-allergen-tag">@allergen.Name</span>
                            }
                        </div>
                    </div>
                }

                <div class="detail-actions">
                    @Html.ActionLink("← Back to Menu", "Index", "Menu", null, new { @class = "btn-back-link" })
                    <form method="post" asp-action="Add" asp-controller="Basket">
                        <input type="hidden" name="foodId" value="@Model.Id" />
                        <button type="submit" class="btn-order">Add to Order</button>
                    </form>
                </div>
            </div>
        </div>

        @if (TempData["BasketMsg"] != null)
        {
            <p class="basket-msg">@TempData["BasketMsg"]</p>
        }

        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <div class="detail-description">
                <p class="detail-section-label">Description</p>
                <p class="detail-description-text">@Model.Description</p>
            </div>
        }

    </div>
</div>