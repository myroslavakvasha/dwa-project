@model WebApp.ViewModels.Category.CategoryVM;

@{
    ViewData["Title"] = "Edit category";
}

@section Styles {
    <link rel="stylesheet" href="/css/form.css" />
}

<div class="food-form-wrapper">
    <div class="food-form-container">
        <h1>Category Management</h1>
        <h2>Edit Category</h2>

        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <input type="hidden" asp-for="Id" />

            <div class="food-form-group">
                <label asp-for="Name"></label>
                <input asp-for="Name" />
                <span asp-validation-for="Name" class="field-validation-error"></span>
            </div>

            <div class="food-form-actions">
                <a asp-action="Index" class="btn-cancel">Cancel</a>
                <input type="submit" value="Save" class="btn-save" />
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
