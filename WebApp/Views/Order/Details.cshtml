@model WebApp.ViewModels.Order.OrderDetailVM

@{
    ViewData["Title"] = "Order details";
}

@section Styles {
    <link rel="stylesheet" href="/css/delete.css" />
    <link rel="stylesheet" href="/css/index.css" />
}

<div class="delete-wrapper">
    <div class="delete-card delete-card--wide">
        <h1>Order #@Model.Id</h1>

        <div class="delete-field">
            <span class="delete-label">Date</span>
            <span class="delete-value">@Model.Date.ToString("dd.MM.yyyy HH:mm")</span>
        </div>
        <div class="delete-field">
            <span class="delete-label">Payment</span>
            <span class="delete-value">@Model.PaymentType</span>
        </div>
        <div class="delete-field">
            <span class="delete-label">Comment</span>
            <span class="delete-value">@(string.IsNullOrEmpty(Model.Comment) ? "—" : Model.Comment)</span>
        </div>

        <div class="food-list-header" style="margin-top: 24px;">
            <span>Food</span>
            <span>Quantity</span>
            <span style="text-align:right">Total price</span>
        </div>

        <div class="food-list">
            @foreach (var item in Model.OrderItems)
            {
                <div class="food-row">
                    <span class="food-row-name">@item.FoodName</span>
                    <span class="food-row-desc">@item.Quantity</span>
                    <span class="food-row-meta">€@item.TotalPrice.ToString("0.00")</span>
                </div>
            }
        </div>

        <div class="delete-field" style="border-top: 2px solid #111; border-bottom: none; margin-top: 0;">
            <span class="delete-label">Total</span>
            <span class="delete-value" style="font-weight: 700;">
                €@Model.OrderItems.Sum(x => x.TotalPrice).ToString("0.00")
            </span>
        </div>

        <div class="delete-actions">
            <a asp-action="Index" asp-route-username="@Model.Username" class="btn-cancel">Back</a>
        </div>
    </div>
</div>